function dec(str)
return str:gsub("\\u(%x%x%x%x)", function(c)
return utf8.char(tonumber(c, 16))
end)
end
a=gg.choice({"查看留言","写留言"},1,"挺长时间没写了有点不熟练了")
if a==1 then
b=gg.prompt({"输入名称"},{""},{"text"})
if a==nil then os.exit() end
body="contacts="..b[1]
head={
["Host"]="wananwain.xqdssnyn.cn",
["Content-Length"]=#body,
["Accept-Language"]="zh-CN,zh;q=0.9,en-US;q=0.8,en;q=0.7",
}
